# Environment Template

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sterling_hms
DB_USER=postgres
DB_PASSWORD=password

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=168h

# Server Configuration
PORT=5000
ENV=development

# Email Configuration (Required for Password Reset)
# Gmail Setup: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your_app_password
FROM_NAME=Sterling HMS

# Email can be sent in development mode by setting ENV=production
# For development testing, set ENV=development and check console for OTP
